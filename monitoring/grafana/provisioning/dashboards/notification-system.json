      "fieldConfig": { "defaults": {}, "overrides": [] },
      "targets": [
        {
          "expr": "asynq_queue_size",
          "legendFormat": "{{queue}} total",
          "refId": "A"
        },
        {
          "expr": "asynq_queue_active",
          "legendFormat": "{{queue}} active",
          "refId": "B"
        },
        {
          "expr": "asynq_queue_pending",
          "legendFormat": "{{queue}} pending",
          "refId": "C"
        },
        {
          "expr": "asynq_queue_retry",
          "legendFormat": "{{queue}} retry",
          "refId": "D"
        }
      ]
    },
    {
      "title": "Webhook Latency (p95)",
